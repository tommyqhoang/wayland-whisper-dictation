#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/dictation-${USER}"
CACHE_DIR="${HOME}/.cache/dictation"
PID_FILE="${STATE_DIR}/arecord.pid"
BUSY_FILE="${STATE_DIR}/transcribing"
WAV_FILE="${CACHE_DIR}/dictation.wav"
LOG_FILE="${CACHE_DIR}/dictation.log"
WORKER_LOG="${CACHE_DIR}/worker.log"
TEXT_FILE="${CACHE_DIR}/last.txt"

first_executable() {
  local candidate
  for candidate in "$@"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

LOCAL_WL_COPY="${HOME}/.local/opt/wl-clipboard-deb/root/usr/bin/wl-copy"
LOCAL_WHISPER_ROOT="${HOME}/.local/opt/whispercpp-deb/root"
LOCAL_WHISPER_BIN="${LOCAL_WHISPER_ROOT}/usr/bin/whisper-cli"
LOCAL_WHISPER_LIB="${LOCAL_WHISPER_ROOT}/usr/lib/x86_64-linux-gnu"
LOCAL_GGML_BACKEND="${LOCAL_WHISPER_LIB}/ggml/backends0/libggml-cpu-x64.so"

ARECORD="${DICTATION_ARECORD:-$(first_executable /usr/bin/arecord "$(command -v arecord 2>/dev/null || true)" || true)}"
NOTIFY="${DICTATION_NOTIFY:-$(first_executable /usr/bin/notify-send "$(command -v notify-send 2>/dev/null || true)" || true)}"
PLAY_SOUND="${DICTATION_PLAY_SOUND:-$(first_executable /usr/bin/canberra-gtk-play "$(command -v canberra-gtk-play 2>/dev/null || true)" || true)}"
WL_COPY="${DICTATION_WL_COPY:-$(first_executable /usr/bin/wl-copy "$(command -v wl-copy 2>/dev/null || true)" "$LOCAL_WL_COPY" || true)}"
WHISPER_BIN="${DICTATION_WHISPER_BIN:-$(first_executable /usr/bin/whisper-cli "$(command -v whisper-cli 2>/dev/null || true)" "$LOCAL_WHISPER_BIN" || true)}"
WHISPER_LIB="${DICTATION_WHISPER_LIB:-}"
GGML_BACKEND="${DICTATION_GGML_BACKEND:-}"
MODEL="${DICTATION_MODEL:-${HOME}/.local/share/whisper.cpp/models/ggml-base.en.bin}"
LANGUAGE="${DICTATION_LANGUAGE:-en}"

if [[ -z "$WHISPER_LIB" && "$WHISPER_BIN" == "$LOCAL_WHISPER_BIN" ]]; then
  WHISPER_LIB="$LOCAL_WHISPER_LIB"
fi
if [[ -z "$GGML_BACKEND" && "$WHISPER_BIN" == "$LOCAL_WHISPER_BIN" && -s "$LOCAL_GGML_BACKEND" ]]; then
  GGML_BACKEND="$LOCAL_GGML_BACKEND"
fi

mkdir -p "$STATE_DIR" "$CACHE_DIR"

notify() {
  if [[ -x "$NOTIFY" ]]; then
    "$NOTIFY" -a "Dictation" -t "${2:-2500}" "Dictation" "$1" 2>/dev/null || true
  fi
}

sound() {
  if [[ -x "$PLAY_SOUND" ]]; then
    "$PLAY_SOUND" -i "$1" >/dev/null 2>&1 || true
  fi
}

clean_text() {
  sed -E \
    -e 's/^[[:space:]]+//' \
    -e 's/[[:space:]]+$//' \
    -e '/^\[(MUSIC PLAYING|BLANK_AUDIO|SILENCE|NO SPEECH)\]$/Id' |
  tr '\n' ' ' |
  sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//' |
  perl -0777 -pe 's/\bnew paragraph\b/\n\n/ig; s/\bnew line\b/\n/ig'
}

is_noise_text() {
  local normalized
  normalized="$(
    printf '%s' "$1" |
      tr '[:upper:]' '[:lower:]' |
      sed -E 's/^[[:space:][:punct:]]+//; s/[[:space:][:punct:]]+$//; s/[[:space:]]+/ /g'
  )"
  case "$normalized" in
    music|beeping|"loud beeping"|silence|"no speech"|scream|screams|screaming|applause)
      return 0
      ;;
  esac
  return 1
}

run_whisper() {
  local env_args=()
  if [[ -n "$WHISPER_LIB" ]]; then
    env_args+=(LD_LIBRARY_PATH="$WHISPER_LIB")
  fi
  if [[ -n "$GGML_BACKEND" ]]; then
    env_args+=(GGML_BACKEND_PATH="$GGML_BACKEND")
  fi

  env "${env_args[@]}" \
    "$WHISPER_BIN" -m "$MODEL" -f "$WAV_FILE" -l "$LANGUAGE" -nt -np 2>>"$LOG_FILE" || true
}

transcribe_to_clipboard() {
  local raw_text text snippet

  echo "$$" > "$BUSY_FILE"
  trap 'rm -f "$BUSY_FILE"' EXIT

  notify "Transcribing..." 4000
  raw_text="$(run_whisper)"
  text="$(printf '%s\n' "$raw_text" | clean_text)"
  if [[ "$text" == *"GGML_ASSERT"* || "$text" == *"GDB supports auto-downloading"* ]]; then
    text=""
  elif is_noise_text "$text"; then
    text=""
  fi

  if [[ -n "$text" ]]; then
    printf '%s\n' "$text" > "$TEXT_FILE"
    printf '%s' "$text" | "$WL_COPY"
    snippet="$text"
    if ((${#snippet} > 120)); then
      snippet="${snippet:0:117}..."
    fi
    sound "complete"
    notify "Copied: ${snippet}" 7000
  else
    : > "$TEXT_FILE"
    sound "dialog-warning"
    notify "No speech detected." 4000
  fi
  rm -f "$BUSY_FILE"
}

if [[ -f "$BUSY_FILE" ]]; then
  busy_pid="$(cat "$BUSY_FILE" 2>/dev/null || true)"
  if [[ -n "${busy_pid:-}" ]] && kill -0 "$busy_pid" 2>/dev/null; then
    notify "Still transcribing the last recording." 2500
    exit 0
  fi
  rm -f "$BUSY_FILE"
fi

if [[ "${1:-}" == "--transcribe" ]]; then
  trap '' HUP
  transcribe_to_clipboard
  exit 0
fi

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    kill -INT "$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    for _ in {1..30}; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
    rm -f "$PID_FILE"

    sound "message"
    setsid -f "$0" --transcribe >"$WORKER_LOG" 2>&1 < /dev/null
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if [[ ! -x "$WHISPER_BIN" || ! -s "$MODEL" || ! -x "$WL_COPY" ]]; then
  notify "Missing whisper-cli, model, or wl-copy. Run the installer first."
  exit 1
fi

rm -f "$WAV_FILE"
"$ARECORD" -D default -f S16_LE -r 16000 -c 1 "$WAV_FILE" >"$LOG_FILE" 2>&1 &
echo "$!" > "$PID_FILE"
notify "Recording... press Super+Shift+D again to stop." 3000
